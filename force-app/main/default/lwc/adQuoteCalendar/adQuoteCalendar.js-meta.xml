<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Ad Quote Calendar</masterLabel>
    <description>A week-based advertisement campaign calendar for showing reserved time periods.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage,lightningCommunity__Default">
            <property
                name="inEnglish"
                label="Display in English"
                description="When toggled on, the text inside the component will switch to English."
                type="Boolean" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
