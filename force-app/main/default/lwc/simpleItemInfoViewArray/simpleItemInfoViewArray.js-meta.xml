<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>EAN Simple Item Info View Array</masterLabel>
    <description>Array of LWC views for showing basic information about s-kaupat.fi products by calling an Apex class for the product html and then scraping it.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="eanCodes" label="Product EAN Codes" type="String[]" role="inputOnly" />
            <property name="imageWidth" label="Image Width" type="Integer" min="32" max="2160" default="360" role="inputOnly" />
            <property name="imageHeight" label="Image Height" type="Integer" min="32" max="2160" default="360" role="inputOnly" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>